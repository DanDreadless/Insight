# Normalise all text files to LF on commit (regardless of OS)
* text=auto eol=lf

# Source files — explicitly LF
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sh        text eol=lf
*.env*      text eol=lf
Dockerfile  text eol=lf
*.dockerignore text eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.zip       binary
*.gz        binary
*.tar       binary
